---
import Layout from '~/layouts/Layout.astro'
import SocialLinks from '~/components/SocialLinks.astro'
import siteConfig from '~/site.config'
import PageHeader from '~/components/PageHeader.astro'
import BlockHeader from '~/components/BlockHeader.astro'
import IconChevronsRight from '~/icons/chevrons-right.svg'
---

<Layout title="Contact" description="Get in touch">
  <div class="mt-2 sm:mt-0">
    <PageHeader title="Contact" />

    <section class="py-8">
      <p class="text-base/7 text-foreground mb-8">
        Want to get in touch? Feel free to reach out via email or connect with me on social media.
      </p>

      {
        siteConfig.socialLinks.email && (
          <div class="mb-8">
            <BlockHeader>Email</BlockHeader>
            <div class="py-6">
              <a
                class="button flex items-center !pl-3.5"
                href={`mailto:${siteConfig.socialLinks.email}`}
              >
                {siteConfig.socialLinks.email}
                <IconChevronsRight class="size-5 ml-2" />
              </a>
            </div>
          </div>
        )
      }

      <BlockHeader>Social</BlockHeader>
      <div class="py-6 flex justify-center">
        <SocialLinks socialLinks={siteConfig.socialLinks} />
      </div>
    </section>
  </div>
</Layout>
