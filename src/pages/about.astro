---
import Layout from '~/layouts/Layout.astro'
import { getCollection, render } from 'astro:content'
import BlockHeader from '~/components/BlockHeader.astro'
import SocialLinks from '~/components/SocialLinks.astro'
import siteConfig from '~/site.config'
import PageHeader from '~/components/PageHeader.astro'
import IconChevronsRight from '~/icons/chevrons-right.svg'

const about = await getCollection('about')
let AboutContent
let skills: string[] = []
let experience: { title: string; company: string; period: string; description: string | string[] }[] = []
let education: { title: string; institution: string; description: string }[] = []
let certifications: { title: string; issuer: string; url?: string }[] = []
let projects: { title: string; description: string; url?: string; tags?: string[] }[] = []
let resumeUrl: string | undefined

if (about.length > 0) {
  const aboutEntry = about[0]
  const { Content } = await render(aboutEntry)
  AboutContent = Content
  skills = aboutEntry.data.skills
  experience = aboutEntry.data.experience
  education = aboutEntry.data.education
  certifications = aboutEntry.data.certifications
  projects = aboutEntry.data.projects
  resumeUrl = aboutEntry.data.resumeUrl
}
---

<Layout title="About" description="About me">
  <div class="mt-2 sm:mt-0">
    <PageHeader title="About" />

    {
      AboutContent && (
        <section class="mt-8">
          <div class="prose">
            <AboutContent />
          </div>
        </section>
      )
    }

    <section class="mt-6">
      <BlockHeader>Connect</BlockHeader>
      <div class="py-6 flex justify-center">
        <SocialLinks socialLinks={siteConfig.socialLinks} />
      </div>
    </section>

    {
      skills.length > 0 && (
        <section>
          <BlockHeader>Skills</BlockHeader>
          <div class="flex flex-wrap gap-2 py-6">
            {skills.map((skill) => (
              <span class="px-3 py-1 text-sm border-2 border-accent/30 rounded-xl text-accent">
                {skill}
              </span>
            ))}
          </div>
        </section>
      )
    }

    {
      experience.length > 0 && (
        <section>
          <details class="group">
            <summary class="cursor-pointer list-none">
              <BlockHeader>
                <span class="flex items-center gap-2">
                  Experience
                  <span class="text-sm text-foreground/50 group-open:rotate-90 transition-transform duration-200">&#9654;</span>
                </span>
              </BlockHeader>
            </summary>
            <div class="py-6 space-y-6">
              {experience.map((job) => (
                <div class="border-l-2 border-accent/30 pl-4">
                  <h3 class="text-lg font-semibold text-heading2">## {job.title}</h3>
                  <p class="text-sm text-foreground/70 mt-1">
                    {job.company} &mdash; {job.period}
                  </p>
                  {Array.isArray(job.description) ? (
                    <ul class="mt-2 list-disc list-inside space-y-1 text-base/7 text-foreground">
                      {job.description.map((point) => (
                        <li>{point}</li>
                      ))}
                    </ul>
                  ) : (
                    <p class="mt-2 text-base/7 text-foreground">{job.description}</p>
                  )}
                </div>
              ))}
            </div>
          </details>
        </section>
      )
    }

    {
      education.length > 0 && (
        <section>
          <details class="group">
            <summary class="cursor-pointer list-none">
              <BlockHeader>
                <span class="flex items-center gap-2">
                  Education
                  <span class="text-sm text-foreground/50 group-open:rotate-90 transition-transform duration-200">&#9654;</span>
                </span>
              </BlockHeader>
            </summary>
            <div class="py-6 space-y-6">
              {education.map((edu) => (
                <div class="border-l-2 border-accent/30 pl-4">
                  <h3 class="text-lg font-semibold text-heading2">## {edu.title}</h3>
                  <p class="text-sm text-foreground/70 mt-1">{edu.institution}</p>
                  <p class="mt-2 text-base/7 text-foreground">{edu.description}</p>
                </div>
              ))}
            </div>
          </details>
        </section>
      )
    }

    {
      certifications.length > 0 && (
        <section>
          <details class="group">
            <summary class="cursor-pointer list-none">
              <BlockHeader>
                <span class="flex items-center gap-2">
                  Certifications
                  <span class="text-sm text-foreground/50 group-open:rotate-90 transition-transform duration-200">&#9654;</span>
                </span>
              </BlockHeader>
            </summary>
            <div class="flex flex-wrap gap-3 py-6">
              {certifications.map((cert) => (
                <div class="border-2 border-accent/20 rounded-xl px-4 py-3">
                  {cert.url ? (
                    <a href={cert.url} target="_blank" rel="noopener noreferrer" class="text-lg font-semibold text-heading2 underline">
                      {cert.title}
                    </a>
                  ) : (
                    <span class="text-lg font-semibold text-heading2">{cert.title}</span>
                  )}
                  <p class="text-sm text-foreground/70 mt-1">{cert.issuer}</p>
                </div>
              ))}
            </div>
          </details>
        </section>
      )
    }

    {
      projects.length > 0 && (
        <section>
          <BlockHeader>Projects</BlockHeader>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 py-6">
            {projects.map((project) => (
              <div class="border-2 border-accent/20 rounded-xl p-4">
                <h3 class="text-lg font-semibold text-heading2">
                  {project.url ? (
                    <a href={project.url} target="_blank" rel="noopener noreferrer">
                      ## {project.title}
                    </a>
                  ) : (
                    <>## {project.title}</>
                  )}
                </h3>
                <p class="mt-2 text-sm text-foreground/80">{project.description}</p>
                {project.tags && project.tags.length > 0 && (
                  <div class="flex flex-wrap gap-1.5 mt-3">
                    {project.tags.map((tag) => (
                      <span class="px-2 py-0.5 text-xs border border-accent/20 rounded-lg text-accent/80">
                        {tag}
                      </span>
                    ))}
                  </div>
                )}
              </div>
            ))}
          </div>
        </section>
      )
    }

    {
      resumeUrl && (
        <section class="pb-6">
          <BlockHeader>Resume</BlockHeader>
          <div class="py-6">
            <a
              class="button flex items-center !pl-3.5"
              href={resumeUrl}
              target="_blank"
              rel="noopener noreferrer"
            >
              Download Resume
              <IconChevronsRight class="size-5 ml-2" />
            </a>
          </div>
        </section>
      )
    }
  </div>
</Layout>
