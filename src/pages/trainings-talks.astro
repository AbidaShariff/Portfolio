---
import Layout from '~/layouts/Layout.astro'
import { getCollection } from 'astro:content'
import PageHeader from '~/components/PageHeader.astro'

const about = await getCollection('about')
let projects: { title: string; description: string; url?: string; tags?: string[] }[] = []

if (about.length > 0) {
  projects = about[0].data.projects
}
---

<Layout title="Trainings/Talks" description="My trainings and talks">
  <div class="mt-2 sm:mt-0">
    <PageHeader title="Trainings/Talks" />

    {
      projects.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 py-8">
          {projects.map((project) => (
            <div class="border-2 border-accent/20 rounded-xl p-5 hover:border-accent/40 transition-colors">
              <h2 class="text-xl font-semibold text-heading1">
                {project.url ? (
                  <a href={project.url} target="_blank" rel="noopener noreferrer">
                    ## {project.title}
                  </a>
                ) : (
                  <>## {project.title}</>
                )}
              </h2>
              <p class="mt-3 text-base/7 text-foreground/80">{project.description}</p>
              {project.tags && project.tags.length > 0 && (
                <div class="flex flex-wrap gap-1.5 mt-4">
                  {project.tags.map((tag) => (
                    <span class="px-2.5 py-0.5 text-sm border border-accent/20 rounded-lg text-accent/80">
                      {tag}
                    </span>
                  ))}
                </div>
              )}
              {project.url && (
                <div class="mt-4">
                  <a
                    class="button flex items-center !pl-3.5 text-sm"
                    href={project.url}
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    View Details
                  </a>
                </div>
              )}
            </div>
          ))}
        </div>
      ) : (
        <p class="py-8 text-foreground/60">No trainings or talks configured yet. Add projects to src/content/about.md.</p>
      )
    }
  </div>
</Layout>
