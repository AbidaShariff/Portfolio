---
import type { Collation } from '~/types'

interface Props {
  tags: Collation<'posts'>[]
}

const { tags } = Astro.props
---

<div class="flex flex-wrap gap-3 text-sm">
  {
    tags.map((tag) => (
      <a
        href={tag.url}
        class="py-1 px-3 bg-accent/5 hover:bg-accent/8 border-1 border-accent/15 text-accent/90 rounded-[3px] transition-all hover:border-accent/40 hover:shadow-[0_0_8px_rgba(245,160,200,0.25),0_0_16px_rgba(245,160,200,0.1)]"
      >
        {tag.title}
      </a>
    ))
  }
</div>
