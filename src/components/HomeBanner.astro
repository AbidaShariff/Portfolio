---
import { Image } from 'astro:assets'
import GitHubActivityCalendar from '~/components/GitHubActivityCalendar.astro'
import siteConfig from '~/site.config'
import type { FrontmatterImage } from '~/types'

interface Props {
  avatarImage?: FrontmatterImage
  githubCalendar?: string
}
const { avatarImage, githubCalendar } = Astro.props
---

<div class="my-6 md:mx-2">
  <!-- Terminal Prompt -->
  <div class="text-[13px] text-foreground/30 mb-4 tracking-wide">
    <span class="text-accent text-glow-sm">abida@root</span>:<span class="text-foreground/50">~/portfolio</span>$ cat about.md
    <span class="cursor-blink"></span>
  </div>

  <!-- Hero Banner -->
  <div
    class="relative border border-accent/15 rounded-[4px] p-7 sm:p-8 bg-accent/5 mb-6"
    style="box-shadow: 0 0 25px rgba(245, 160, 200, 0.07), 0 0 50px rgba(245, 160, 200, 0.04), 0 0 80px rgba(245, 160, 200, 0.02), inset 0 0 35px rgba(245, 160, 200, 0.025);"
  >
    <span class="absolute -top-2.5 left-4 bg-background px-2 text-[11px] text-foreground/30 tracking-wider">// about.md</span>

    <!-- Name -->
    <h1 class="text-[2rem] font-bold text-heading1 leading-tight mb-2">{siteConfig.title}</h1>

    <!-- Title + Certs -->
    <p class="text-sm font-medium text-accent tracking-wide mb-5 leading-relaxed">
      <span class="text-glow-sm">Lead Security Engineer</span> &nbsp;|&nbsp; OSCP &nbsp;|&nbsp; CEH &nbsp;|&nbsp; eJPT
    </p>

    <!-- Separator -->
    <div class="h-px mb-5" style="background: linear-gradient(to right, rgba(245, 160, 200, 0.15), transparent 60%); box-shadow: 0 0 8px rgba(245, 160, 200, 0.1);"></div>

    <!-- Description -->
    <div class="text-sm leading-[1.85] text-foreground font-light mb-7 max-w-full prose">
      <slot />
    </div>

    <!-- Stats Bar -->
    <div class="stats-bar">
      <div class="stat-item">
        <div class="stat-value text-glow-sm">6+</div>
        <div class="stat-label">Years Experience</div>
      </div>
      <div class="stat-item">
        <div class="stat-value text-glow-sm">150+</div>
        <div class="stat-label">Pentesting Projects</div>
      </div>
      <div class="stat-item">
        <div class="stat-value text-glow-sm">200+</div>
        <div class="stat-label">Vulnerabilities Found</div>
      </div>
      <div class="stat-item">
        <div class="stat-value text-glow-sm">500+</div>
        <div class="stat-label">Students Mentored</div>
      </div>
    </div>
  </div>
  {githubCalendar && <GitHubActivityCalendar username={githubCalendar} />}
</div>
